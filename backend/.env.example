DATABASE_URL=sqlite+pysqlite:///./job_agent.db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_ALWAYS_EAGER=true
CELERY_TASK_EAGER_PROPAGATES=false

LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

RESUME_STORAGE_DIR=storage/resumes
ARTIFACTS_DIR=artifacts

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TEST_URL=https://example.com
MAX_RESUME_SIZE_MB=8
AUTOPILOT_CYCLE_MINUTES=30
ALLOWED_APPLICATION_HOST_SUFFIXES=["greenhouse.io", "lever.co"]
STORE_RESUME_RAW_TEXT=false
RESUME_UPLOAD_RATE_LIMIT_COUNT=12
RESUME_UPLOAD_RATE_LIMIT_WINDOW_SECONDS=3600
JOBS_SCRAPE_RATE_LIMIT_COUNT=20
JOBS_SCRAPE_RATE_LIMIT_WINDOW_SECONDS=3600
APPLICATIONS_SUBMIT_RATE_LIMIT_COUNT=20
APPLICATIONS_SUBMIT_RATE_LIMIT_WINDOW_SECONDS=3600
AUTOPILOT_RUN_NOW_RATE_LIMIT_COUNT=6
AUTOPILOT_RUN_NOW_RATE_LIMIT_WINDOW_SECONDS=3600

CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
SUPPORT_EMAIL=support@example.com
