{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "candidate_profile.schema.json",
  "title": "CandidateProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["first_name", "last_name", "email", "skills", "experience"],
  "properties": {
    "first_name": {"type": "string"},
    "last_name": {"type": "string"},
    "email": {"type": "string", "format": "email"},
    "phone": {"type": "string"},
    "location": {"type": "string"},
    "headline": {"type": "string"},
    "summary": {"type": "string"},
    "github_url": {"type": "string", "format": "uri"},
    "linkedin_url": {"type": "string", "format": "uri"},
    "website_url": {"type": "string", "format": "uri"},
    "skills": {
      "type": "array",
      "items": {"type": "string"}
    },
    "education_history": {
      "type": "array",
      "items": {"$ref": "#/$defs/educationEntry"}
    },
    "experience": {
      "type": "array",
      "items": {"$ref": "#/$defs/experienceEntry"}
    },
    "projects": {
      "type": "array",
      "items": {"$ref": "#/$defs/projectEntry"}
    },
    "certifications": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "educationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["school_name"],
      "properties": {
        "school_name": {"type": "string"},
        "degree": {"type": "string"},
        "field_of_study": {"type": "string"},
        "start_date": {"type": "string"},
        "end_date": {"type": "string"}
      }
    },
    "experienceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["company", "title"],
      "properties": {
        "company": {"type": "string"},
        "title": {"type": "string"},
        "start_date": {"type": "string"},
        "end_date": {"type": "string"},
        "location": {"type": "string"},
        "summary": {"type": "string"},
        "highlights": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "projectEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "url": {"type": "string", "format": "uri"},
        "highlights": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
